{
	"name": "@molos/module-markdown",
	"version": "1.0.0",
	"type": "module",
	"description": "MoLOS Markdown Module - Hierarchical markdown document management with tree navigation, versioning, and search",
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./config": "./src/config.ts",
		"./models": "./src/models/index.ts",
		"./ai": "./src/server/ai/ai-tools.ts"
	},
	"files": ["src", "manifest.yaml", "drizzle"],
	"scripts": {
		"build": "echo 'No build required for source module'",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"dependencies": {
		"zod": "^3.0.0",
		"lucide-svelte": "^0.561.0",
		"marked": "^15.0.0"
	},
	"peerDependencies": {
		"@molos/database": "workspace:*",
		"@molos/module-types": "workspace:*",
		"svelte": "^5.45.0",
		"@sveltejs/kit": "^2.0.0",
		"drizzle-orm": "^0.41.0"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.49.2",
		"drizzle-orm": "^0.41.0",
		"svelte": "^5.46.1",
		"typescript": "^5.0.0",
		"vitest": "^4.0.16"
	},
	"publishConfig": {
		"access": "public"
	}
}
